# MS Word documents
application/msword; mail-view-attachment %s doc
application/vnd.openxmlformats-officedocument.spreadsheetml.sheet; mail-view-attachment %s doc

# Images
image/jpg; mail-view-attachment %s jpg
image/jpeg; mail-view-attachment %s jpg
image/pjpeg; mail-view-attachment %s jpg
image/png; mail-view-attachment %s png
image/gif; mail-view-attachment %s gif

# PDFs
application/pdf; mail-view-attachment %s pdf

# HTML
## text/html; mail-view-attachment %s html
#text/html; w3m -o auto_image=TRUE %s -T text/html; nametemplate=%s.html
#text/html; w3m -o auto_image=TRUE %s -T text/html; nametemplate=%s.html; copiousoutput
#text/html; w3m -o auto_image=TRUE %s -T text/html; nametemplate=%s.html; needsterminal

text/html;  mail-view-attachment %s html
text/html;  w3m -I %{charset} -o auto_image=TRUE %s -T text/html; nametemplate=%s.html; copiousoutput

# Unidentified files
application/octet-stream; mail-view-attachment %s "-"

