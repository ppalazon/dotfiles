# For environment variables and early session configuration

export XDG_CURRENT_DESKTOP=
#export QT_QPA_PLATFORMTHEME="qt5ct"
export QT_QTA_PLATFORMTHEME=gtk3
export QT_AUTO_SCREEN_SCALE_FACTOR=0
export QT_SCALE_FACTOR=1

# HiDPI scaling
# export QT_AUTO_SCREEN_SCALE_FACTOR=1
# export QT_ENABLE_HIGHDPI_SCALING=1
# export GDK_SCALE=2
# export GDK_DPI_SCALE=1.0

unset SSH_AGENT_PID
export SSH_AUTH_SOCK=${XDG_RUNTIME_DIR}/gnupg/S.gpg-agent.ssh

export PATH="/usr/local/texlive/2026/bin/x86_64-linux:$PATH"
export PATH="$PATH:$HOME/.local/bin:$HOME/bin:$HOME/bin/sh"
export GOPATH=$HOME/go

[ -n "$DISPLAY" ] && export BROWSER=firefox || export BROWSER=links
[ -n "$DISPLAY" ] && export EDITOR=kate || export EDITOR=nvim