type = internal/tray
format = <tray>
format-margin = 8px
tray-spacing = 8px
              
[module/xwindow]
type = internal/xwindow
label = %title:0:20:...%

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

format-prefix = "´ä£ "
