[module/bspwm]
type = internal/bspwm

label-focused = %index%
label-focused-background = ${colors.background-inverse}
label-focused-underline= ${colors.foreground}
label-focused-padding = 2

label-occupied = %index%
label-occupied-padding = 2

label-urgent = %index%!
