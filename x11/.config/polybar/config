label-empty = %index%
label-empty-foreground = ${colors.foreground-inverse}
label-empty-padding = 2

; Separator in between workspaces
; label-separator = |

[module/i3]
type = internal/i3

format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false

pin-workspaces = true
strip-wsnumbers = true
fuzzy-match = true

; Workspace icons
ws-icon-0 = vv;´äá
ws-icon-1 = browser;´ë®
ws-icon-2 = code;´äí
ws-icon-3 = spotify;´å╝
ws-icon-4 = comm;´üÁ
ws-icon-default = ´äë


; ---- MODE (resize etc) ----
label-mode-padding = 2
label-mode-foreground = ${colors.foreground-inverse}
label-mode-background = ${colors.background-inverse}


; ---- FOCUSED workspace ----
label-focused = %index% %icon%
label-focused-padding = 2
label-focused-foreground = ${colors.foreground-inverse}
label-focused-background = ${colors.background-inverse}
; label-focused-underline = ${colors.active-led}


; ---- UNFOCUSED workspace ----
label-unfocused = %index% %icon%
label-unfocused-padding = 2
label-unfocused-foreground = ${colors.foreground-faded}
label-unfocused-background = ${colors.background}


; ---- VISIBLE workspace (other monitor) ----
label-visible = %index% %icon%
label-visible-padding = 2
label-visible-foreground = ${colors.foreground-inverse}
label-visible-background = ${colors.background-inverse}
label-visible-underline = ${colors.foreground-prefix}


; ---- URGENT workspace ----
label-urgent = %index% %icon%
label-urgent-padding = 2
label-urgent-foreground = ${colors.background}
label-urgent-background = ${colors.alert}


; optional separator
; label-separator = |

