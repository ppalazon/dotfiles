\ProvidesPackage{beamercolorthemeatr}

\usepackage{xcolor}

% Define colors
\definecolor{atrgreen}{RGB}{136,177, 55}
\definecolor{atrgreenlight}{RGB}{170,209, 93}
\definecolor{atrgreenlighter}{RGB}{209,240,147}
\definecolor{atrblack}{RGB}{ 80, 79, 81}
\definecolor{atryellow}{RGB}{190,178, 59}
\definecolor{atrred}{RGB}{190, 96, 59}
\definecolor{atrblue}{RGB}{255,140,0}

% Apply colors
\setbeamercolor{structure}{fg=atrgreen}
\setbeamercolor{frametitle}{fg=atrgreen, bg=atrblack}
\setbeamercolor{title}{fg=atrgreen, bg=atrblack}
\setbeamercolor{subtitle}{fg=atrblack}
\setbeamercolor{alerted text}{fg=atrred}
\setbeamercolor{item}{fg=atrblue}
\setbeamercolor{block title}{fg=white, bg=atrblack}
\setbeamercolor{block body}{bg=atrblue!10}

% Optional: Change sidebar or navigation colors
\setbeamercolor{palette primary}{fg=atrblack, bg=atrgreen}
\setbeamercolor{palette secondary}{fg=atrblack, bg=atrgreenlight}
\setbeamercolor{palette tertiary}{fg=atrblack, bg=atrgreenlighter}