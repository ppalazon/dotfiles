#!/usr/bin/env bash

set -eou pipefail

GEOMETRY=${1:-}

if [[ -z "$GEOMETRY" ]]; then
  echo "$0 <geometry>" >&2
  notify-send "No geometry provided" "Please provide a geometry string as an argument, or use the screenshot-select-capture script to select an area interactively."
  exit 1
fi

SCREENSHOT_DIR="${SCREENSHOT_DIR:-$HOME/pictures/screen}"
mkdir -p "$SCREENSHOT_DIR"

FILENAME="$SCREENSHOT_DIR/screenshot-$(date +%Y%m%d-%H%M%S).png"
maim -g "$GEOMETRY" -u "$FILENAME"

# Reduce the image to get max quality for printing on a A4 paper, but keeping original ratio
# A4 paper has 8.27x11.69 inches, using margin of 1 inch, we get 6.27x9.69 inches, at 300 DPI, we get 1881x2907 pixels, but we want to limit the width to 2181 pixels to get better quality for printing
MAX_WIDTH=1881
MAX_HEIGHT=2907
convert "$FILENAME" \
  -strip \
  -units PixelsPerInch \
  -density 300 \
  -resize "${MAX_WIDTH}x${MAX_HEIGHT}>" \
  "$FILENAME"

# Save latest geometry for repeat captures
echo "$GEOMETRY" > /tmp/screenshot-geometry

xclip -selection clipboard -t image/png -i "$FILENAME"
echo "$FILENAME" | xclip -selection primary 

notify-send "Screenshot saved and on clipboard" "$FILENAME"