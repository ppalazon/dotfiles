#!/bin/bash
set -euo pipefail

cd "$HOME"

HOST=$(hostname)
OUTPUT_DIR=~/.secrets-backup
mkdir -p $OUTPUT_DIR
chmod 700 $OUTPUT_DIR
DATE=$(date +%Y%m%d)
rm -f ~/.ssh/ssm-ssh-tmp-*

TARGET_FILE=$OUTPUT_DIR/$DATE-$HOST-secrets-dotfiles.tar.age

FILES_TO_BACKUP=()

for f in \
  .owm-key \
  .netrc \
  .ssh \
  .gnupg \
  .keepassxc \
  .password-store \
  .certificates \
  .config/git/identities.conf \
  .docker/config.json \
  .local/share/keyrings
do
  [[ -e "$f" ]] && FILES_TO_BACKUP+=("$f")
done

tar -cvf - -C $HOME "${FILES_TO_BACKUP[@]}" | age -p -o $TARGET_FILE
chmod 600 $TARGET_FILE