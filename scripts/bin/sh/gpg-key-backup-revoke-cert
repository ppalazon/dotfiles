#!/usr/bin/env bash

set -euo pipefail

KEY_INPUT="${1:-}"

if [[ -z "$KEY_INPUT" ]]; then
  echo "Usage: $0 <key-id-or-email>"
  exit 1
fi

# Get fingerprint (canonical ID)
FPR="$(gpg-key-fingerprint $KEY_INPUT)"

if [[ -z "$FPR" ]]; then
  echo "Error: Key not found: $KEY_INPUT"
  exit 1
fi

echo "Found key fingerprint: $FPR"

# Ensure revocation directory exists
REV_DIR="${GNUPGHOME:-$HOME/.gnupg}/backups/revs"
mkdir -p "$REV_DIR"
chmod 700 "$REV_DIR"

if [ "$(findmnt -n -o FSTYPE /tmp)" != "tmpfs" ]; then
  echo "⚠️ Warning: /tmp is not a tmpfs. This may be less secure for temporary storage of sensitive key material."
fi
TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT
chmod 700 "$TMP_DIR"

REV_TMP_FILE="$TMP_DIR/${FPR}-revocation.asc"
ENCRYPTED_OUTPUT_FILE="$REV_DIR/${FPR}-revocation.asc.age"

if [[ -f "$ENCRYPTED_OUTPUT_FILE" ]]; then
  echo "Encrypted revocation certificate already exists:"
  echo "  $ENCRYPTED_OUTPUT_FILE"
  exit 0
fi

HAS_MASTER_KEY=$(gpg --list-secret-keys --with-colons $FPR | awk -F: '/^sec/ {print $15; exit}')

if [ "$HAS_MASTER_KEY" = "#" ]; then
  echo "⚠️ Your master key is currently offline."
  exit 1
fi

echo
echo "Creating revocation certificate..."

gpg -a --output "$REV_TMP_FILE" --gen-revoke "$FPR"
chmod 600 "$REV_TMP_FILE"

echo
echo "Creating encrypted backup archive..."
age -p -o "$ENCRYPTED_OUTPUT_FILE" "$REV_TMP_FILE"
chmod 600 "$ENCRYPTED_OUTPUT_FILE"
shred -u "$REV_TMP_FILE" || rm -f "$REV_TMP_FILE"

echo
echo "Revocation certificate saved to:"
echo "  $ENCRYPTED_OUTPUT_FILE"