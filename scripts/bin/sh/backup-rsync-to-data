#!/usr/bin/env bash

set -euo pipefail

HOST=$(hostname)
REMOTE_HOST="data"
DIR_DEST="/data/backup/rsync/$HOST"
REPOSITORY_DEST="$REMOTE_HOST:$DIR_DEST"
INCLUDE_PATH_FILE="$HOME/.config/rsync/backup-paths.txt"

if [[ ! -f "$INCLUDE_PATH_FILE" ]]; then
  echo "Include path file not found: $INCLUDE_PATH_FILE"
  exit 1
fi

echo "Creating backup directory on remote server: $REPOSITORY_DEST"
ssh data "mkdir -p $DIR_DEST"

while IFS= read -r path; do
  [[ -z "$path" || "$path" =~ ^[[:space:]]*# ]] && continue    
  
  name=$(basename "$path")
  name="${name/#./dot-}"

  echo "Syncing $path to $REPOSITORY_DEST/$name"

  if [[ -d "$path" ]]; then
    echo "Syncing directory: $path"
    rsync -avzP --delete "$path/" "$REPOSITORY_DEST/$(basename "$path")/"
  elif [[ -f "$path" ]]; then
    echo "Syncing file: $path"
    rsync -avzP "$path" "$REPOSITORY_DEST/$(basename "$path")"
  else
    echo "Path not found: $path"
  fi
done < "$INCLUDE_PATH_FILE"