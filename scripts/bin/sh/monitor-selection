#!/usr/bin/env bash

set -euo pipefail

LAYOUT_DIR="$HOME/.screenlayout"
mkdir -p "$LAYOUT_DIR"

choice=$(
  find "$LAYOUT_DIR" -maxdepth 1 \( -type f -o -type l \) -name "*.sh" -printf "%f\n" \
  | sed 's/\.sh$//' \
  | sort \
  | rofi -dmenu -i -p "Monitor Layout" 
  # | fzf \
  #     --prompt="Monitor Layout > " \
  #     --height=40% \
  #     --border \
  #     --reverse
)

if [[ -n "${choice:-}" ]]; then
  monitor-init-layout "$LAYOUT_DIR/$choice.sh"
  notify-send "Monitor layout" "Loaded: $choice"
fi