#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $0 [--list] [--overwrite] [--dry-run] <backup-file.age>"
  exit 1
}

LIST=0
OVERWRITE=0
DRY_RUN=0

# Parse args
while [[ $# -gt 0 ]]; do
  case "$1" in
    --list)
      LIST=1
      shift
      ;;
    --overwrite)
      OVERWRITE=1
      shift
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    -*)
      echo "Unknown option: $1"
      usage
      ;;
    *)
      BACKUP_FILE="$1"
      shift
      ;;
  esac
done

[[ -z "${BACKUP_FILE:-}" ]] && usage

# ✅ Safety: ensure we're in HOME
if [[ "$PWD" != "$HOME" ]]; then
  echo "❌ You must run this script from your home directory"
  echo "Current: $PWD"
  echo "Expected: $HOME"
  exit 1
fi

# ✅ Check file exists
if [[ ! -f "$BACKUP_FILE" ]]; then
  echo "❌ Backup file not found: $BACKUP_FILE"
  exit 1
fi

echo "Using backup: $BACKUP_FILE"
echo

# 📋 LIST MODE
if [[ $LIST -eq 1 ]]; then
  echo "📦 Archive contents:"
  age -d "$BACKUP_FILE" | tar -tvf -
  exit 0
fi

# 🧪 DRY RUN MODE
if [[ $DRY_RUN -eq 1 ]]; then
  echo "🧪 Dry run (no files will be written):"
  age -d "$BACKUP_FILE" | tar -tvf -
  exit 0
fi

# 🔄 RESTORE MODE
echo "Restoring files..."

TAR_FLAGS="-xvf -"

if [[ $OVERWRITE -eq 0 ]]; then
  TAR_FLAGS="-xvkf -"  # keep existing files
  echo "⚠️  Not overwriting existing files (use --overwrite to change)"
else
  echo "⚠️  Overwriting existing files"
fi

age -d "$BACKUP_FILE" | tar $TAR_FLAGS

echo
echo "✅ Restore completed"