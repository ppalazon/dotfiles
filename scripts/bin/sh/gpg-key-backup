#!/usr/bin/env bash

set -euo pipefail

KEY_INPUT="${1:-}"

if [[ -z "$KEY_INPUT" ]]; then
  echo "Usage: $0 <key-id-or-email>"
  exit 1
fi

# Get fingerprint (canonical ID)
FPR="$(gpg-key-fingerprint $KEY_INPUT)"

if [[ -z "$FPR" ]]; then
  echo "Error: Key not found: $KEY_INPUT"
  exit 1
fi
echo "Found key fingerprint: $FPR"

HAS_MASTER_KEY=$(gpg --list-secret-keys --with-colons $FPR | awk -F: '/^sec/ {print $15; exit}')

if [ "$HAS_MASTER_KEY" = "#" ]; then
  echo "⚠️ Your master key is currently offline."
  exit 1
fi

# Ensure revocation directory exists
EXPORT_DIR="${GNUPGHOME:-$HOME/.gnupg}/backups/keys"
mkdir -p "$EXPORT_DIR"
chmod 700 "$EXPORT_DIR"

if [ "$(findmnt -n -o FSTYPE /tmp)" != "tmpfs" ]; then
  echo "⚠️ Warning: /tmp is not a tmpfs. This may be less secure for temporary storage of sensitive key material."
fi
TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT
chmod 700 "$TMP_DIR"

DATE=$(date +%Y%m%d)
# REV_FILE="$TMP_DIR/${FPR}-revocation.asc"
PUBLIC_FILE="${TMP_DIR}/${FPR}-public.gpg"
FULL_PRIVATE_FILE="${TMP_DIR}/${FPR}-full.gpg"
# MINIMAL_PRIVATE_FILE="${TMP_DIR}/${FPR}-minimal.gpg"
SUBKEYS_PRIVATE_FILE="${TMP_DIR}/${FPR}-subkeys.gpg"
BACKUP_FILE="$EXPORT_DIR/${DATE}-${FPR}-backup.tar.age"

# echo "Exporting revocation certificate..."
# gpg --output "$REV_FILE" --gen-revoke "$FPR"
# chmod 600 "$REV_FILE"

echo "Exporting public key..."
gpg --export "$FPR" > "$PUBLIC_FILE"
chmod 644 "$PUBLIC_FILE"

echo "Exporting full private key... (Waiting for your GPG passphrase if needed)"
gpg --export-secret-keys "$FPR" > "$FULL_PRIVATE_FILE"
chmod 600 "$FULL_PRIVATE_FILE"

# echo "Exporting minimal private key..."
# gpg --export-secret-keys \
#     --export-options export-minimal \
#     "$FPR" > "$MINIMAL_PRIVATE_FILE"
# chmod 600 "$MINIMAL_PRIVATE_FILE"

echo "Exporting subkeys... (Waiting for your GPG passphrase if needed)"
gpg --export-secret-subkeys "$FPR" > "$SUBKEYS_PRIVATE_FILE"
chmod 600 "$SUBKEYS_PRIVATE_FILE"

echo
echo "Creating encrypted backup archive... (Use a new passphrase to encrypt the backup)"
tar -cf - -C $TMP_DIR . | age -p -o $BACKUP_FILE
chmod 600 "$BACKUP_FILE"

# Securely overwrite and remove temporary files
# shred -u "$REV_FILE"
shred -u "$PUBLIC_FILE"
shred -u "$FULL_PRIVATE_FILE" 
# shred -u "$MINIMAL_PRIVATE_FILE"
shred -u "$SUBKEYS_PRIVATE_FILE"

echo
echo "✅ Done"
echo "Encrypted backup:"
echo "  $BACKUP_FILE"