#!/usr/bin/env bash

set -euo pipefail

KEY_INPUT="${1:-}"

if [[ -z "$KEY_INPUT" ]]; then
  echo "Usage: $0 <key-id-or-email>"
  exit 1
fi

# Get fingerprint (canonical ID)
FPR=$(gpg --list-keys --with-colons "$KEY_INPUT" 2>/dev/null \
  | awk -F: '/^fpr:/ { print $10; exit }')

if [[ -z "$FPR" ]]; then
  echo "Error: Key not found: $KEY_INPUT"
  exit 1
fi
echo "Found key fingerprint: $FPR"

EXPORT_DIR="${GNUPGHOME:-$HOME/.gnupg}/exports"
mkdir -p "$EXPORT_DIR"
chmod 700 "$EXPORT_DIR"

# Extract email (robust)
EMAIL=$(gpg --list-keys --with-colons "$FPR" \
  | awk -F: '/^uid:/ { print $10; exit }' \
  | sed -n 's/.*<\([^>]*\)>.*/\1/p')

if [[ -z "$EMAIL" ]]; then
  echo "Error: Could not extract email from key"
  exit 1
fi

# Validate email format (basic)
if [[ ! "$EMAIL" =~ ^[^@]+@[^@]+\.[^@]+$ ]]; then
  echo "Error: Invalid email extracted: $EMAIL"
  exit 1
fi

WKD_LINE=$(gpg --list-keys --with-wkd "$KEY_INPUT" 2>/dev/null \
  | grep '@' \
  | grep -v '^uid' \
  | head -n1 || true)

if [[ -z "$WKD_LINE" ]]; then
  echo "Error: Could not extract WKD information for $KEY_INPUT"
  exit 1
fi

WKD_HASH=$(echo "$WKD_LINE" \
  | awk '{print $1}' \
  | cut -d@ -f1)

if [[ -z "$WKD_HASH" ]]; then
  echo "Error: Failed to extract WKD hash"
  exit 1
fi

DOMAIN="${EMAIL##*@}"
OUTPUT_FILE="$EXPORT_DIR/$WKD_HASH"

echo "Key:         $KEY_INPUT"
echo "Fingerprint: $FPR"
echo "Email:       $EMAIL"
echo "Domain:      $DOMAIN"
echo "WKD hash:    $WKD_HASH"
echo "Output file: $OUTPUT_FILE"
echo
echo "Exporting key..."

# IMPORTANT: binary export
gpg --export "$FPR" > "$OUTPUT_FILE"
chmod 644 "$OUTPUT_FILE"

echo
echo "✅ Export complete:"
echo "  $OUTPUT_FILE"

# Deployment instructions
WKD_PATH="/.well-known/openpgpkey/hu/$WKD_HASH"

echo
echo "📦 Installation instructions:"
echo
echo "1. Copy the file to your web server:"
echo
echo "   $WKD_PATH"
echo
echo "2. Ensure HTTPS is enabled (required by WKD)"
echo
echo "3. Ensure file is publicly accessible:"
echo "   chmod 644 $WKD_PATH"
echo
echo "4. Test it:"
echo
echo "   gpg --auto-key-locate wkd --locate-keys $EMAIL"
echo "   gpg-key-wkd-import $EMAIL"
echo
echo "🌍 Expected URL:"
echo "   https://$DOMAIN$WKD_PATH"