#!/usr/bin/env bash
if [[ -n $(pgrep 'restic' | grep 'restic backup') ]]; then
  echo 'restic is already running...' 1>&2
  exit 0
fi

# Check whether external drive is connected (/media/elements)
uuid=2f263d2d-4296-4d19-ba2a-0ee7c7d1f872
if [[ -z $(lsblk -f | grep $uuid) ]]; then
  echo "WD Elements driver is not connected at an usb port and mount at /media/elements"
  exit 0
fi

if [ "$EUID" -ne 0 ]
  then echo "Please run as root"
  exit
fi

set -e
set -v

HOSTNAME=$(hostname)

export RESTIC_REPOSITORY="/media/elements/restic/$HOSTNAME"
export RESTIC_PASSWORD_COMMAND="pass restic/$HOSTNAME"
export RESTIC_COMPRESSION='off'
export RESTIC_CACHE_DIR=/root/.cache/restic
 
mkdir -p "${RESTIC_CACHE_DIR}"
 
restic unlock 
restic backup / --exclude-file=/etc/restic/excludes.txt --tag scheduled 
restic check --with-cache --read-data-subset=5G
restic forget --prune --keep-hourly 24 --keep-daily 30 --keep-monthly 6 --keep-weekly 4 --keep-yearly 3
