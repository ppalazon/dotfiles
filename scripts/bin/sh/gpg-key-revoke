#!/usr/bin/env bash

set -euo pipefail

KEY_INPUT="${1:-}"
REV_FILE="${2:-}"

if [[ -z "$KEY_INPUT" || -z "$REV_FILE" ]]; then
  echo "Usage: $0 <key-id-or-email> <revocation-file.age>"
  exit 1
fi

if [[ ! -f "$REV_FILE" ]]; then
  echo "Error: File not found: $REV_FILE"
  exit 1
fi

# Resolve fingerprint of target key
FPR=$(gpg --list-keys --with-colons "$KEY_INPUT" 2>/dev/null \
  | awk -F: '/^fpr:/ { print $10; exit }')

if [[ -z "$FPR" ]]; then
  echo "Error: Key not found: $KEY_INPUT"
  exit 1
fi

echo "Target key fingerprint: $FPR"

TMP_FILE=$(mktemp)
trap 'rm -f "$TMP_FILE"' EXIT

echo "Decrypting revocation certificate..."
age -d -o "$TMP_FILE" "$REV_FILE"

# Basic validation: must look like a PGP block
if ! grep -q "BEGIN PGP PUBLIC KEY BLOCK" "$TMP_FILE"; then
  echo "Error: Not a valid ASCII-armored OpenPGP block"
  exit 1
fi

echo "Inspecting revocation certificate..."

gpg --list-packets "$TMP_FILE"

REV_FPR=$(gpg --list-packets "$TMP_FILE" \
  | sed -n 's/.*issuer fpr v[0-9]* \([0-9A-F]\{40\}\).*/\1/p' \
  | head -n1)

if [[ -z "$REV_FPR" ]]; then
  echo "Error: Could not extract issuer fingerprint from revocation certificate"
  exit 1
fi

echo "Revocation certificate fingerprint: $REV_FPR"
echo "Expected fingerprint:               $FPR"

if [[ "$REV_FPR" != "$FPR" ]]; then
  echo "Error: Fingerprint mismatch!"
  exit 1
fi

echo "Fingerprint matches ✔"

echo
echo "About to import revocation certificate."
read -rp "Continue? [y/N] " CONFIRM

if [[ "$CONFIRM" != "y" && "$CONFIRM" != "Y" ]]; then
  echo "Aborted."
  exit 1
fi

echo "Importing revocation certificate..."

gpg --import "$TMP_FILE"

echo
echo "Verifying..."

gpg --list-keys "$FPR"

echo
echo "Done. Key should now be revoked."