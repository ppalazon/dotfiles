#!/usr/bin/env bash

set -euo pipefail

KEY_INPUT="${1:-}"
BACKUP_FILE="${2:-}"

if [[ -z "$KEY_INPUT" || -z "$BACKUP_FILE" ]]; then
  echo "Usage: $0 <backup_file> <key-id-or-email> "
  exit 1
fi

if [[ ! -f "$BACKUP_FILE" ]]; then
  echo "Error: File not found: $BACKUP_FILE"
  exit 1
fi

# Get fingerprint (canonical ID)
FPR=$(gpg-key-fingerprint "$KEY_INPUT")

if [[ -z "$FPR" ]]; then
  echo "Error: Key not found: $KEY_INPUT"
  exit 1
fi

echo "Found key fingerprint: $FPR"
echo

HAS_MASTER_KEY=$(gpg --list-secret-keys --with-colons $FPR | awk -F: '/^sec/ {print $15; exit}')

if [ "$HAS_MASTER_KEY" = "+" ]; then
  echo "Error: This master key is already online."
  exit 1
fi

echo "Restoring master key from backup..."
TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT
chmod 700 "$TMP_DIR"

DECRYPTED_TAR="$TMP_DIR/backup.tar"
FULL_KEY_FILE="$TMP_DIR/${FPR}-full.gpg"

echo "Decrypting backup..."
age -d -o "$DECRYPTED_TAR" "$BACKUP_FILE"

echo "Extracting archive..."
tar -xf "$DECRYPTED_TAR" -C "$TMP_DIR"

FILE_FPR=$(gpg --show-keys --with-colons "$FULL_KEY_FILE" 2>/dev/null \
    | awk -F: '/^fpr:/ { print $10; exit }')


if [[ "$FILE_FPR" != "$FPR" ]]; then
  echo "Error: Fingerprint mismatch. Expected $FPR but got $FILE_FPR"
  exit 1
fi

echo "✅ Fingerprint validation passed"

echo "Importing master key from backup..."
gpg --import "$FULL_KEY_FILE"

echo "✅ Master key restored successfully"
echo "⚠️ Remember to take out the master on your daily machine."