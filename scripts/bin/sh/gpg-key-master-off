#!/usr/bin/env bash

set -euo pipefail

KEY_INPUT="${1:-}"
DESTINATION="${2:-}"

if [[ -z "$KEY_INPUT" || -z "$DESTINATION" ]]; then
  echo "Usage: $0 <destination-dir> <key-id-or-email>"
  exit 1
fi

if [[ ! -d "$DESTINATION" ]]; then
  echo "Error: Destination must be a directory"
  exit 1
fi

# Get fingerprint (canonical ID)
FPR="$(gpg-key-fingerprint $KEY_INPUT)"

if [[ -z "$FPR" ]]; then
  echo "Error: Key not found: $KEY_INPUT"
  exit 1
fi
echo "Found key fingerprint: $FPR"

HAS_MASTER_KEY=$(gpg --list-secret-keys --with-colons $FPR | awk -F: '/^sec/ {print $15; exit}')

if [ "$HAS_MASTER_KEY" = "#" ]; then
  echo "Error: This master key is already offline."
  exit 1
fi

DATE=$(date +%Y%m%d)
EXPORT_DIR="${GNUPGHOME:-$HOME/.gnupg}/backups/keys"
BACKUP_FILE="$EXPORT_DIR/${DATE}-${FPR}-backup.tar.age"
DESTINATION_FILE="$DESTINATION/${FPR}-master.tar.age"

echo "Creating a backup..."
gpg-key-backup $FPR

TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT
chmod 700 "$TMP_DIR"

DECRYPTED_TAR="$TMP_DIR/backup.tar"
SUBKEYS_PRIVATE_FILE="${TMP_DIR}/${FPR}-subkeys.gpg"

echo
echo "Decrypting backup... (Waiting for your encryption backup passphrase)"
age -d -o "$DECRYPTED_TAR" "$BACKUP_FILE"
tar -xf "$DECRYPTED_TAR" -C "$TMP_DIR"

echo "Deleting existing key..."
gpg --delete-secret-keys --batch --yes $FPR

echo "Importing subkeys from backup... (Waiting for your GPG passphrase if needed)"
gpg --import "$SUBKEYS_PRIVATE_FILE"

echo "Exporting master key to destination..."
mv "$BACKUP_FILE" "$DESTINATION_FILE"
chmod 600 "$DESTINATION_FILE"

echo "Done."
echo "✅ Master key removed from local machine"
echo "✅ Only subkeys remain"
echo "✅ Full backup stored at: $DESTINATION_FILE"