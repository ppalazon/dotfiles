#!/usr/bin/env bash

set -euo pipefail

BACKUP_FILE="${1:-}"

if [[ -z "$BACKUP_FILE" ]]; then
  echo "Usage: $0 <backup-file.age>"
  exit 1
fi

if [[ ! -f "$BACKUP_FILE" ]]; then
  echo "Error: File not found: $BACKUP_FILE"
  exit 1
fi

if [ "$(findmnt -n -o FSTYPE /tmp)" != "tmpfs" ]; then
  echo "⚠️ Warning: /tmp is not a tmpfs. This may be less secure for temporary storage of sensitive key material."
fi
TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT
chmod 700 "$TMP_DIR"

DECRYPTED_TAR="$TMP_DIR/backup.tar"

echo "🔓 Decrypting backup..."
age -d -o "$DECRYPTED_TAR" "$BACKUP_FILE"

echo "📦 Extracting archive..."
tar -xf "$DECRYPTED_TAR" -C "$TMP_DIR"

echo
echo "📂 Contents:"
ls -l "$TMP_DIR"
echo

KEY_FILES=($(find "$TMP_DIR" -type f -name "*.gpg"))

if [[ ${#KEY_FILES[@]} -eq 0 ]]; then
  echo "❌ No GPG key files found"
  exit 1
fi

echo "🔍 Verifying key files..."
echo

for KEY_FILE in "${KEY_FILES[@]}"; do
  echo "========================================"
  echo "File: $KEY_FILE"
  echo

  # Show key info
  gpg --show-keys --with-fingerprint "$KEY_FILE" || true
  echo

  # Extract fingerprint
  FPR=$(gpg --show-keys --with-colons "$KEY_FILE" 2>/dev/null \
    | awk -F: '/^fpr:/ { print $10; exit }')

  if [[ -z "$FPR" ]]; then
    echo "❌ Could not extract fingerprint"
    continue
  fi

  echo "Fingerprint: $FPR"

  # Check if present in current keyring
  if gpg --list-secret-keys "$FPR" >/dev/null 2>&1; then
    echo "✅ Present in current keyring"
  else
    echo "⚠️ Not present in current keyring"
  fi

  echo
done

echo "🧪 Testing import in isolated environment..."

TEST_GNUPG="$TMP_DIR/test-gnupg"
mkdir -p "$TEST_GNUPG"
chmod 700 "$TEST_GNUPG"

IMPORT_OK=true

for KEY_FILE in "${KEY_FILES[@]}"; do
  echo "Import test: $KEY_FILE"

  if GNUPGHOME="$TEST_GNUPG" gpg --import "$KEY_FILE" >/dev/null 2>&1; then
    echo "  ✔ Import successful"
  else
    echo "  ❌ Import failed"
    IMPORT_OK=false
  fi
done

echo
echo "🔎 Listing imported keys in test environment:"
GNUPGHOME="$TEST_GNUPG" gpg --list-secret-keys --with-fingerprint

echo
if $IMPORT_OK; then
  echo "✅ Verification successful: backup is valid and importable"
else
  echo "❌ Verification failed: some keys could not be imported"
  exit 1
fi

echo
echo "🧹 Cleaning up..."
shred -u "$DECRYPTED_TAR" || rm -f "$DECRYPTED_TAR"

echo
echo "✅ Done"