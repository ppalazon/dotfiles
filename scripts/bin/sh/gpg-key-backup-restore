#!/usr/bin/env bash

set -euo pipefail

BACKUP_FILE="${1:-}"

if [[ -z "$BACKUP_FILE" ]]; then
  echo "Usage: $0 <backup-file.age>"
  exit 1
fi

if [[ ! -f "$BACKUP_FILE" ]]; then
  echo "Error: File not found: $BACKUP_FILE"
  exit 1
fi

if [ "$(findmnt -n -o FSTYPE /tmp)" != "tmpfs" ]; then
  echo "⚠️ Warning: /tmp is not a tmpfs. This may be less secure for temporary storage of sensitive key material."
fi
TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT
chmod 700 "$TMP_DIR"

DECRYPTED_TAR="$TMP_DIR/backup.tar"

echo "Decrypting backup..."
age -d -o "$DECRYPTED_TAR" "$BACKUP_FILE"

echo "Extracting archive..."
tar -xf "$DECRYPTED_TAR" -C "$TMP_DIR"

echo
echo "📦 Contents:"
ls -l "$TMP_DIR"
echo

# Find exported keys
KEY_FILES=($(find "$TMP_DIR" -type f -name "*.gpg"))

if [[ ${#KEY_FILES[@]} -eq 0 ]]; then
  echo "No GPG key files found in backup"
  exit 1
fi

echo "🔍 Inspecting keys..."
echo

for KEY_FILE in "${KEY_FILES[@]}"; do
  echo "----------------------------------------"
  echo "File: $KEY_FILE"
  echo

  # Show key info
  gpg --show-keys --with-fingerprint "$KEY_FILE" || true
  echo

  # Extract fingerprint from file
  FPR=$(gpg --show-keys --with-colons "$KEY_FILE" 2>/dev/null \
    | awk -F: '/^fpr:/ { print $10; exit }')

  if [[ -z "$FPR" ]]; then
    echo "⚠️ Could not extract fingerprint"
    continue
  fi

  echo "Fingerprint: $FPR"

  # Check if key already exists
  if gpg --list-secret-keys "$FPR" >/dev/null 2>&1; then
    echo "⚠️ Key already exists in your keyring"
    read -rp "Do you want to re-import it? [y/N]: " ANSWER
  else
    echo "✅ Key not present in keyring"
    read -rp "Import this key? [y/N]: " ANSWER
  fi

  if [[ "$ANSWER" =~ ^[Yy]$ ]]; then
    echo "Importing..."
    gpg --import "$KEY_FILE"
    echo "✔ Imported"
  else
    echo "Skipped"
  fi

  echo
done

echo "🧹 Cleaning up temporary files..."

# Optional secure deletion
rm -f "$DECRYPTED_TAR"

echo
echo "✅ Restore process finished"