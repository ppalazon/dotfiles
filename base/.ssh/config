ServerAliveCountMax 3
ServerAliveInterval 10
AddKeysToAgent yes

Include ~/.ssh/conf.d/*

Match Host i-*
  User ec2-user
  ProxyCommand bash -c "AWS_PROFILE=default ~/workspace/3rd-party/ssh-over-ssm/ssh-ssm.sh %h %r"
  IdentityFile ~/.ssh/ssm-ssh-tmp
  StrictHostKeyChecking no
  PasswordAuthentication no
  GSSAPIAuthentication no

